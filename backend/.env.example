# Server Configuration
PORT=5000

# Google Sheets Configuration
# Retrieve these by creating a Service Account in Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id

# Twilio WhatsApp Configuration
# Retrieve these from your Twilio Console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
BUSINESS_WHATSAPP_NUMBERS=whatsapp:+919704710017,whatsapp:+919666480610
